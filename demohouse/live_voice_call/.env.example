# Required runtime credentials
ARK_API_KEY=your_ark_api_key
LLM1_ENDPOINT_ID=your_llm1_endpoint_id
LLM2_ENDPOINT_ID=your_llm2_endpoint_id
LLM1_THINKING_TYPE=disabled
LLM2_THINKING_TYPE=disabled
# Only effective when THINKING_TYPE=enabled
# LLM1_REASONING_EFFORT=minimal
# LLM2_REASONING_EFFORT=minimal
ASR_APP_ID=your_asr_app_id
ASR_ACCESS_TOKEN=your_asr_access_token
TTS_APP_ID=your_tts_app_id
TTS_ACCESS_TOKEN=your_tts_access_token
TTS_SPEAKER=your_tts_speaker

# Let's Encrypt contact email
LETSENCRYPT_EMAIL=2377963631@qq.com

# Admin account
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_now

# Public URL used in interview links
PUBLIC_INTERVIEW_BASE_URL=https://smartinterview.cn/check-in

# Optional CORS override for admin API (comma-separated)
# ADMIN_CORS_ORIGINS=https://smartinterview.cn

# Optional backend tuning
# Optional frontend dev proxy target (use when localhost:8890 is occupied)
# ADMIN_API_PROXY_TARGET=http://127.0.0.1:18990
# LLM_CONCURRENT_REQUESTS=5
# MAX_ACTIVE_INTERVIEWS=5
# QUEUE_WAIT_TIMEOUT_SECONDS=1800
# ASYNC_LOG_QUEUE_SIZE=10000
# ASYNC_LOG_FLUSH_INTERVAL_MS=200
# ASYNC_LOG_DROP_POLICY=drop_oldest
# ASYNC_LOG_CLOSE_TIMEOUT_SECONDS=5
# INTERVIEW_LOGGER_CACHE_MAX=1000
# INTERVIEW_LOGGER_IDLE_SECONDS=900
# FRONTEND_LOG_MAX_BODY_BYTES=262144
# FRONTEND_LOG_MAX_ENTRIES=200
# FRONTEND_LOG_MAX_ENTRY_CHARS=2000
