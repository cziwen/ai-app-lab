# Required runtime credentials
ARK_API_KEY=your_ark_api_key
LLM_ENDPOINT_ID=your_llm_endpoint_id
ASR_APP_ID=your_asr_app_id
ASR_ACCESS_TOKEN=your_asr_access_token
TTS_APP_ID=your_tts_app_id
TTS_ACCESS_TOKEN=your_tts_access_token
TTS_SPEAKER=your_tts_speaker

# Admin account
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_now

# Public URL used in interview links
PUBLIC_INTERVIEW_BASE_URL=https://smartinterview.cn/check-in

# Optional CORS override for admin API (comma-separated)
# ADMIN_CORS_ORIGINS=https://smartinterview.cn

# Optional backend tuning
# LLM_CONCURRENT_REQUESTS=5
# MAX_ACTIVE_INTERVIEWS=5
# QUEUE_WAIT_TIMEOUT_SECONDS=1800
